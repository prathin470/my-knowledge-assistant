# Top-level Spectrum credentials (from your Photon dashboard).
PROJECT_ID= 
PROJECT_SECRET= 

# OpenRouter (https://openrouter.ai/keys) — powers document-section elaboration.
OPENROUTER_API_KEY=
# Any OpenRouter model id, e.g. openai/gpt-4o-mini, anthropic/claude-3.5-sonnet, google/gemini-flash-1.5
OPENROUTER_MODEL=openai/gpt-4o-mini

# Path to the Markdown document the assistant elaborates on. Drop your .md here.
DOC_PATH=./knowledge.md

# Daily morning discourse prompt. LEARNER_PHONE is the number to send it to
# (the number you text the assistant from). Leave blank to disable the prompt.
LEARNER_PHONE=
# Name shown in the morning greeting ("Good Morning <name>☀️"). Default [Name].
LEARNER_NAME=[Name]
# 5-field cron, in the MORNING_TZ timezone. Default: 08:00 every day.
MORNING_CRON=0 8 * * *
MORNING_TZ=Australia/Sydney
